# Level Agency package registry proxy
# Authentication is handled per-environment:
#   - Local dev: NPM_TOKEN env var set to a GitHub PAT with read:packages scope
#   - CI/Vercel: NPM_TOKEN env var set to a GitHub PAT with read:packages scope
@levelinteractive:registry=https://dash.level.agency/api/npm-registry
//dash.level.agency/api/npm-registry/:_authToken=${NPM_TOKEN}
