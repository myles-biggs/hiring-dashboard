generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth ─────────────────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  emailVerified DateTime?
  name          String?
  image         String?
  role          Role      @default(HIRING_MANAGER)
  isApprover    Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts Account[]
  sessions Session[]
}

enum Role {
  HIRING_MANAGER
  TALENT_ACQUISITION
  ADMIN
  TA
  VIEWER
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Hiring Brief Cache ───────────────────────────────────────────────────────

model HiringBrief {
  id                   String         @id @default(cuid())
  asanaTaskId          String         @unique
  workableJobId        String?        @unique

  roleTitle            String
  department           String
  hiringManagerEmail   String
  employmentType       String
  salaryRangeMin       Int?
  salaryRangeMax       Int?
  yearsExperience      Int?
  targetStartDate      DateTime?
  roleSummary          String?        @db.Text
  hardSkills           String?        @db.Text
  softSkills           String?        @db.Text

  approvalStatus       ApprovalStatus @default(PENDING)
  approverName         String?
  approvedAt           DateTime?
  approvalNote         String?
  approverEmail        String?

  jdEnglish            String?        @db.Text
  jdFrench             String?        @db.Text
  jdGeneratedAt        DateTime?

  archivedAt           DateTime?

  createdAt            DateTime       @default(now())
  updatedAt            DateTime       @updatedAt

  candidateCache CandidateCache[]
}

enum ApprovalStatus {
  PENDING
  APPROVED
  REJECTED
  ESCALATED
}

// ─── Candidate Cache ──────────────────────────────────────────────────────────

model CandidateCache {
  id                  String   @id @default(cuid())
  workableCandidateId String   @unique
  workableJobId       String

  name                String
  email               String
  currentStage        String
  appliedAt           DateTime

  resumeUrl           String?
  linkedinUrl         String?

  aiVetScore          Int?
  aiVetStatus         String?
  aiVetSummary        String?  @db.Text
  aiVetRationale      String?  @db.Text
  aiVetQuestions      String[]
  aiVetRunAt          DateTime?

  isSilverMedalist    Boolean  @default(false)
  silverMedalistNote  String?

  country             String?
  city                String?

  briefId             String?
  brief               HiringBrief? @relation(fields: [briefId], references: [id])

  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  @@index([workableJobId])
}

// ─── Candidate Evaluations ────────────────────────────────────────────────────

model CandidateEvaluation {
  id                   String   @id @default(cuid())
  workableCandidateId  String
  workableJobId        String
  pipelineStage        String
  evaluatorEmail       String
  evaluatorName        String?

  cvTruth              String
  cvResults            String
  cvBetterEveryDay     String
  cvNoEgo              String

  gwcGetsIt            Boolean
  gwcWantsIt           Boolean
  gwcCapacity          Boolean

  performance          String
  futureReadiness      String

  notes                String?  @db.Text
  meetsThreshold       Boolean
  recommendation       String
  overrideReason       String?  @db.Text
  overrideByEmail      String?
  overrideAt           DateTime?

  workableCommentPosted   Boolean  @default(false)
  workableCommentPostedAt DateTime?

  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  @@index([workableCandidateId, pipelineStage])
}

// ─── Audit Log ────────────────────────────────────────────────────────────────

model AuditEvent {
  id         String   @id @default(cuid())
  actorEmail String
  eventType  String
  entityId   String
  entityType String
  metadata   Json?
  createdAt  DateTime @default(now())
}
